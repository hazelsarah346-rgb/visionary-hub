# ─────────────────────────────────────────────────────────────────
# Visionary Hub — ROOT .env (server / API keys)
# Copy to .env:  cp .env.example .env
# Fill in your keys. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── AI (required for Opportunities, AI Tutor, Mentor generation, Vision Board) ──
# Option A — Groq (free, fast): https://console.groq.com → Create API Key
GROQ_API_KEY=gsk_YOUR_ACTUAL_KEY_HERE

# Option B — Claude (Anthropic): https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ───────────────────────────────────────────────────────
PORT=3001

# ─────────────────────────────────────────────────────────────────
# Supabase keys go in client/.env (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)
# so the frontend can connect. See SETUP-GUIDE.md → API Keys.
# ─────────────────────────────────────────────────────────────────
